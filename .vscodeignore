# Dev-only directories
.vscode/**
.vscode-test/**
.github/**
.claude/**
coverage/**
node_modules/**
src/**

# Unbundled tsc output — extension entry is dist/extension.js
out/**

# Dev-only files
.gitignore
.prettierignore
.prettierrc.json
package-lock.json
vsc-extension-quickstart.md
esbuild.mjs
**/tsconfig.json
**/eslint.config.mjs
**/.vscode-test.*
**/vitest.config.*

# Build artifacts (sourcemaps excluded; bundled dist/extension.js still ships)
**/*.map
**/*.ts

# Icon sources (only the rendered PNG ships)
media/build_icon.py
media/icon.svg
