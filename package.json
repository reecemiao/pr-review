{
  "name": "pr-review",
  "displayName": "PR Review",
  "description": "Review GitHub Enterprise pull requests using GitHub Copilot, with confirmation before posting.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:prReview.run",
    "onCommand:prReview.runFromPrList"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prReview.run",
        "title": "PR Review: Review current branch",
        "category": "PR Review"
      },
      {
        "command": "prReview.runFromPrList",
        "title": "Review with PR Review",
        "category": "PR Review"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "prReview.run"
        },
        {
          "command": "prReview.runFromPrList",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "prReview.runFromPrList",
          "when": "view == pr:github && viewItem =~ /pullrequest/",
          "group": "prreview@1"
        }
      ]
    },
    "configuration": {
      "title": "PR Review",
      "properties": {
        "prReview.baseBranch": {
          "type": "string",
          "default": "origin/master",
          "description": "Base branch to diff the current branch against."
        },
        "prReview.model.vendor": {
          "type": "string",
          "default": "copilot",
          "description": "Language model vendor (passed to vscode.lm.selectChatModels)."
        },
        "prReview.model.family": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Language model family (e.g. gpt-4o, claude-sonnet-4)."
        },
        "prReview.toolScope": {
          "type": "string",
          "enum": [
            "read-only",
            "read-only-with-linters",
            "shell-with-confirm"
          ],
          "default": "read-only",
          "markdownDescription": "What the agent is allowed to run:\n- `read-only`: filesystem reads, grep, git show/log/diff\n- `read-only-with-linters`: above plus auto-invoke common linters (ruff/mypy/bandit/eslint)\n- `shell-with-confirm`: agent can propose any shell command; user approves each"
        },
        "prReview.extraInstructions": {
          "type": "object",
          "default": {},
          "description": "Extra instruction markdown files appended per language, e.g. { \"python\": \"./team-python.md\" }. Paths are resolved relative to the workspace folder.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "prReview.githubEnterprise.baseUrl": {
          "type": "string",
          "default": "",
          "description": "GitHub Enterprise API base URL (e.g. https://github.example.com/api/v3). Leave empty for github.com."
        },
        "prReview.maxAgentIterations": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "description": "Safety cap on agent tool-call iterations per review."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint && npm run format:check",
    "typecheck": "tsc -p ./ --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vscode-test"
  },
  "dependencies": {
    "@octokit/rest": "^21.1.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "prettier": "3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
