{
    "name": "pr-review",
    "displayName": "PR Review",
    "description": "Review GitHub Enterprise pull requests using GitHub Copilot, with confirmation before posting.",
    "version": "0.1.3",
    "publisher": "reecemiao",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/reecemiao/pr-review.git"
    },
    "bugs": {
        "url": "https://github.com/reecemiao/pr-review/issues"
    },
    "engines": {
        "vscode": "^1.120.0"
    },
    "categories": [
        "AI",
        "SCM Providers",
        "Linters"
    ],
    "keywords": [
        "pull request",
        "pr review",
        "code review",
        "github",
        "github enterprise",
        "copilot",
        "language model",
        "ai review"
    ],
    "icon": "media/icon.png",
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "prReview.run",
                "title": "Review current branch",
                "category": "PR Review"
            },
            {
                "command": "prReview.reviewBranch",
                "title": "Review another branch…",
                "category": "PR Review"
            },
            {
                "command": "prReview.reviewPrNoCheckout",
                "title": "Review PR (without checkout)",
                "category": "PR Review"
            },
            {
                "command": "prReview.reviewPrCheckout",
                "title": "Checkout & Review PR",
                "category": "PR Review"
            },
            {
                "command": "prReview.reviewPrWorktree",
                "title": "Review PR in worktree",
                "category": "PR Review"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "prReview.run"
                },
                {
                    "command": "prReview.reviewBranch"
                },
                {
                    "command": "prReview.reviewPrNoCheckout",
                    "when": "false"
                },
                {
                    "command": "prReview.reviewPrCheckout",
                    "when": "false"
                },
                {
                    "command": "prReview.reviewPrWorktree",
                    "when": "false"
                }
            ],
            "view/item/context": [
                {
                    "command": "prReview.reviewPrNoCheckout",
                    "when": "view == pr:github && viewItem =~ /pullrequest/",
                    "group": "prreview@1"
                },
                {
                    "command": "prReview.reviewPrCheckout",
                    "when": "view == pr:github && viewItem =~ /pullrequest/",
                    "group": "prreview@2"
                },
                {
                    "command": "prReview.reviewPrWorktree",
                    "when": "view == pr:github && viewItem =~ /pullrequest/",
                    "group": "prreview@3"
                }
            ]
        },
        "configuration": {
            "title": "PR Review",
            "properties": {
                "prReview.baseBranch": {
                    "type": "string",
                    "default": "origin/master",
                    "description": "Base branch to diff the current branch against."
                },
                "prReview.model.vendor": {
                    "type": "string",
                    "default": "copilot",
                    "description": "Language model vendor (passed to vscode.lm.selectChatModels)."
                },
                "prReview.model.family": {
                    "type": "string",
                    "default": "gpt-5-mini",
                    "description": "Language model family (e.g. gpt-4o, claude-sonnet-4)."
                },
                "prReview.toolScope": {
                    "type": "string",
                    "enum": [
                        "read-only",
                        "read-only-with-linters",
                        "shell-with-confirm"
                    ],
                    "default": "read-only",
                    "markdownDescription": "What the agent is allowed to run:\n- `read-only`: filesystem reads, grep, git show/log/diff\n- `read-only-with-linters`: above plus auto-invoke common linters (ruff/mypy/bandit/eslint)\n- `shell-with-confirm`: agent can propose any shell command; user approves each"
                },
                "prReview.extraInstructions": {
                    "type": "object",
                    "default": {},
                    "description": "Extra instruction markdown files appended per language, e.g. { \"python\": \"./.review/team-python.md\" }. Paths are resolved relative to the git repo root (so the same setting works whether VS Code is opened at the repo root or a subdirectory).",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "prReview.githubEnterprise.baseUrl": {
                    "type": "string",
                    "default": "",
                    "description": "GitHub Enterprise API base URL (e.g. https://github.example.com/api/v3). Leave empty for github.com."
                },
                "prReview.maxAgentIterations": {
                    "type": "number",
                    "default": 20,
                    "minimum": 1,
                    "description": "Safety cap on agent tool-call iterations per review."
                },
                "prReview.thinkingEffort": {
                    "type": "string",
                    "enum": [
                        "minimal",
                        "low",
                        "medium",
                        "high"
                    ],
                    "default": "medium",
                    "markdownDescription": "Reasoning effort hint passed to the language model via `modelOptions.reasoning_effort`. Only applies to models that support it (e.g. gpt-5-mini, o-series). `minimal` is fastest; `high` does the most thinking."
                },
                "prReview.debugLog": {
                    "type": "boolean",
                    "default": false,
                    "description": "Verbose logging in the PR Review Output Channel: full prompts, tool inputs, and tool results. Off by default; the channel still records iteration counts, tool calls, durations, and errors."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run bundle:prod",
        "bundle": "node esbuild.mjs",
        "bundle:prod": "node esbuild.mjs --production",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "watch:bundle": "node esbuild.mjs --watch",
        "pretest": "npm run compile && npm run bundle && npm run lint && npm run format:check",
        "typecheck": "tsc -p ./ --noEmit",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:integration": "vscode-test",
        "test": "vscode-test",
        "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test:unit && npm run compile && npm run bundle",
        "package": "vsce package",
        "publish": "vsce publish"
    },
    "dependencies": {
        "@octokit/rest": "^21.1.1"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.120.0",
        "@vitest/coverage-v8": "4.1.7",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.9.1",
        "esbuild": "^0.28.0",
        "eslint": "^9.39.3",
        "eslint-config-prettier": "10.1.8",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-import": "2.32.0",
        "prettier": "3.8.3",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vitest": "4.1.7"
    }
}
